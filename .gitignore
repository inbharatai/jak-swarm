node_modules/
.turbo/
dist/
.next/
*.local
# Environment files — root + every workspace package + every app.
# Belt and suspenders: previously `.env` only matched the root file, so
# apps/api/.env could slip through (and did, in this repo's history).
# Each pattern now covers its scope explicitly. Allow only `.env.example`
# to remain tracked.
.env
.env.*
!.env.example
apps/*/.env
apps/*/.env.*
!apps/*/.env.example
packages/*/.env
packages/*/.env.*
!packages/*/.env.example
.env.*.local
coverage/
*.log
prisma/migrations/
*.tsbuildinfo

.vercel
scripts/create-render-service.ps1

.vercel
.env*.local

# Generated by `pnpm check:truth`
docs/_generated/

# Automation script env files — never commit real creds
scripts/automation/.env.*
.env.render-*
.env.vercel-*

# Playwright + test artifacts (transient — produced by QA test runs, never source-of-truth)
qa/playwright-artifacts/
qa/post-fix-playwright-artifacts/
qa/_generated/
qa/_findings-pretty.json
qa/_selectors.json
tests/test-results/
playwright-report/

# Tesseract.js OCR training data — auto-downloaded on first parseImage run (~5MB).
# Cached locally; never committed.
*.traineddata
