generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tenant {
  id                      String   @id @default(cuid())
  name                    String
  slug                    String   @unique
  status                  String   @default("ACTIVE") // TenantStatus enum
  plan                    String   @default("FREE")   // TenantPlan enum
  industry                String?  // Industry enum
  requireApprovals        Boolean  @default(true)
  // When false (default for NEW tenants), every task routed to the approval
  // node pauses for human review regardless of approvalThreshold. When true,
  // tasks with risk strictly below approvalThreshold auto-approve. Existing
  // tenants are back-filled to `true` in the migration to preserve behavior;
  // only tenants created AFTER the migration get the strict default.
  autoApproveEnabled      Boolean  @default(false)
  approvalThreshold       String   @default("HIGH")   // RiskLevel
  allowedDomains          String[] @default([])
  maxConcurrentWorkflows  Int      @default(5)
  enableVoice             Boolean  @default(true)
  enableBrowserAutomation Boolean  @default(false)
  disabledToolNames       String[] @default([])
  logRetentionDays        Int      @default(90)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  users            User[]
  workflows        Workflow[]
  workflowJobs     WorkflowJob[]
  skills           Skill[]
  auditLogs        AuditLog[]
  memory           TenantMemory[]
  memoryItems      MemoryItem[]
  memoryEvents     MemoryEvent[]
  apiKeys          ApiKey[]
  integrations    Integration[]
  oauthStates     OAuthState[]
  whatsappLinks  WhatsappLink[]
  onboardingState OnboardingState?
  schedules       WorkflowSchedule[]
  projects        Project[]
  vectorDocuments VectorDocument[]
  tenantDocuments TenantDocument[]
  subscription    Subscription?
  companyProfile  CompanyProfile?

  @@map("tenants")
}

model User {
  id           String   @id @default(cuid())
  tenantId     String
  email        String
  name         String?
  passwordHash String?
  role         String   @default("END_USER") // UserRole enum
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  jobFunction  String?
  avatarUrl    String?

  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sessions  Session[]
  workflows Workflow[]
  workflowJobs WorkflowJob[]
  approvals ApprovalRequest[] @relation("reviewer")
  projects  Project[]
  whatsappLinks WhatsappLink[]

  @@unique([tenantId, email])
  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("sessions")
}

model ApiKey {
  id         String    @id @default(cuid())
  tenantId   String
  name       String
  keyHash    String    @unique
  scopes     String[]  @default([])
  expiresAt  DateTime?
  lastUsedAt DateTime?
  createdAt  DateTime  @default(now())

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("api_keys")
}

model Workflow {
  id            String    @id @default(cuid())
  tenantId      String
  userId        String
  goal          String
  industry      String?
  status        String    @default("PENDING") // WorkflowStatus
  planJson      Json?     // WorkflowPlan serialized
  currentTaskId String?
  error         String?
  stateJson     Json?
  finalOutput   String?   @db.Text
  totalCostUsd  Float     @default(0)
  maxCostUsd    Float?
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  updatedAt     DateTime  @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user             User              @relation(fields: [userId], references: [id])
  traces           AgentTrace[]
  approvalRequests ApprovalRequest[]
  jobs             WorkflowJob[]
  artifacts        WorkflowArtifact[]

  @@index([tenantId, status])
  @@index([updatedAt])
  @@map("workflows")
}

// Hardening pass — foundation for the Audit & Compliance product.
//
// A WorkflowArtifact is a customer-deliverable evidence artefact produced
// by a workflow run: the final output (markdown), an exported PDF/DOCX/CSV,
// a worker-generated file, an evidence bundle ZIP, etc. Distinct from
// AgentTrace (per-step internal record) and TenantDocument (user-uploaded
// inputs) — both of which already exist.
//
// Storage policy:
//   - Small text/JSON artefacts: stored inline in `inlineContent` (≤256KB).
//   - Larger binary artefacts: stored in Supabase Storage at `storageKey`
//     under bucket `tenant-artifacts/<tenantId>/<workflowId>/<id>.<ext>`.
//   - Both fields can be null while `status='PENDING'` (artifact row created
//     before the file is materialised — see `artifact.service.ts`).
//
// Approval gating:
//   - `approvalState='REQUIRES_APPROVAL'` means the artifact was produced
//     by a high-risk workflow and must NOT be downloaded until reviewed.
//   - Download routes MUST check approvalState before signing a URL.
model WorkflowArtifact {
  id              String    @id @default(cuid())
  tenantId        String
  workflowId      String
  // Optional — when an artifact corresponds to a single workflow task.
  taskId          String?
  // Who/what produced the artifact. Worker role for agent output, 'system'
  // for export bundles, the user id for explicit user uploads.
  producedBy      String
  // Stable type label used by the audit UI for filtering. Open vocabulary
  // because the Audit & Compliance product will introduce new types
  // (evidence_bundle, control_attestation, signed_export, etc.) without
  // a Prisma migration each time.
  artifactType    String    // e.g. 'final_output' | 'export' | 'evidence_bundle' | 'attachment'
  // Human-friendly file name shown in the UI.
  fileName        String
  mimeType        String
  // Total size in bytes. NULL until the artifact materializes.
  sizeBytes       Int?
  // sha256 of the bytes — for integrity check + dedupe across a tenant.
  contentHash     String?
  // For small text/JSON artefacts kept inline. Null for binary objects in storage.
  inlineContent   String?   @db.Text
  // Supabase Storage key for binary objects. Null for inline-only.
  storageKey      String?   @unique
  // Lifecycle:
  //   PENDING   — row created, file not yet written
  //   READY     — file materialised (inline or storage), download allowed pending approval
  //   FAILED    — production failed; see `error`
  //   DELETED   — soft-delete, blob removed but row stays for audit trail
  status          String    @default("PENDING")
  // Compliance gate. The Audit & Compliance product reads this to enforce
  // "evidence cannot be exported until human-approved" workflows.
  //   NOT_REQUIRED         — artifact is non-sensitive, downloadable freely
  //   REQUIRES_APPROVAL    — approval gate active; download blocked
  //   APPROVED             — reviewer approved download
  //   REJECTED             — reviewer blocked download permanently
  approvalState   String    @default("NOT_REQUIRED")
  // When approvalState transitions to APPROVED/REJECTED, who decided.
  approvedBy      String?
  approvedAt      DateTime?
  // Audit field — last user who DOWNLOADED. Per-download events live in AuditLog.
  lastDownloadedBy String?
  lastDownloadedAt DateTime?
  // For multi-format exports — track the source artifact ID.
  // E.g. a PDF export of an evidence_bundle ZIP keeps `parentId` pointing at the bundle.
  parentId        String?
  // Free-form metadata the producer wants stamped on the row (workflow step
  // id, source dataset version, signing key id, etc.).
  metadata        Json?
  error           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  // Soft-delete marker. Hard-delete is reserved for retention sweeps.
  deletedAt       DateTime?

  workflow        Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  parent          WorkflowArtifact? @relation("ArtifactParent", fields: [parentId], references: [id], onDelete: SetNull)
  derivatives     WorkflowArtifact[] @relation("ArtifactParent")

  @@index([tenantId, deletedAt])
  @@index([workflowId])
  @@index([tenantId, artifactType])
  @@index([tenantId, status])
  @@map("workflow_artifacts")
}

model WorkflowJob {
  id               String   @id @default(cuid())
  workflowId       String   @unique
  tenantId         String
  userId           String
  status           String   @default("QUEUED") // QUEUED | ACTIVE | COMPLETED | FAILED | DEAD
  attempts         Int      @default(0)
  maxAttempts      Int      @default(5)
  payloadJson      Json
  availableAt      DateTime @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  lastError        String?
  // P1b ownership — which instance owns the job right now, when its lease expires,
  // and when it last heartbeated. Reclaim when leaseExpiresAt < NOW() and status='ACTIVE'.
  ownerInstanceId  String?
  leaseExpiresAt   DateTime?
  lastHeartbeatAt  DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, availableAt])
  @@index([tenantId, status])
  @@index([updatedAt])
  @@index([status, leaseExpiresAt])
  @@index([ownerInstanceId])
  @@map("workflow_jobs")
}

model AgentTrace {
  id            String    @id @default(cuid())
  traceId       String
  runId         String
  workflowId    String
  tenantId      String
  agentRole     String    // AgentRole enum
  stepIndex     Int
  inputJson     Json?
  outputJson    Json?
  toolCallsJson Json?
  handoffsJson  Json?
  startedAt     DateTime
  completedAt   DateTime?
  durationMs    Int?
  tokenUsage    Json?
  error         String?

  workflow      Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@index([workflowId])
  @@index([traceId])
  @@index([tenantId])
  @@map("agent_traces")
}

model ApprovalRequest {
  id               String    @id @default(cuid())
  workflowId       String
  tenantId         String
  taskId           String
  agentRole        String
  action           String
  rationale        String
  proposedDataJson Json?
  riskLevel        String    @default("HIGH")
  status           String    @default("PENDING") // PENDING | APPROVED | REJECTED | DEFERRED
  comment          String?
  reviewedBy       String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  workflow         Workflow  @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  reviewer         User?     @relation("reviewer", fields: [reviewedBy], references: [id])

  @@index([workflowId, status])
  @@index([tenantId, status])
  @@map("approval_requests")
}

// Append-only audit log of every approval decision ever made, including
// auto-approvals, rejections, deferrals, and human approvals. This is the
// source of truth for compliance queries ("prove who approved action X on
// date Y") and for observing tenant auto-approve behaviour over time.
//
// Rows are NEVER deleted except via explicit data-retention jobs; updating
// the ApprovalRequest row does not mutate the history recorded here.
model ApprovalAuditLog {
  id             String   @id @default(cuid())
  approvalId     String   // FK to ApprovalRequest (soft ref — kept even after request cleanup)
  workflowId     String
  tenantId       String
  taskId         String
  agentRole      String
  riskLevel      String
  decision       String   // APPROVED | REJECTED | DEFERRED | AUTO_APPROVED
  autoApproved   Boolean  @default(false)
  approverId     String?  // null for auto-approvals
  rationale      String?
  rawDecisionJson Json?   // full request body for forensic debugging
  decidedAt      DateTime @default(now())

  @@index([tenantId, decidedAt])
  @@index([workflowId])
  @@index([approvalId])
  @@map("approval_audit_logs")
}

model Skill {
  id               String    @id @default(cuid())
  tenantId         String?   // null = global built-in
  name             String
  description      String
  tier             Int       @default(1) // SkillTier
  status           String    @default("PROPOSED") // SkillStatus
  inputSchemaJson  Json?
  outputSchemaJson Json?
  permissions      String[]  @default([])
  riskLevel        String    @default("MEDIUM")
  testCasesJson    Json?
  implementation   String?   // source code — only for sandbox
  sandboxResult    Json?
  approvedBy       String?
  approvedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  tenant           Tenant?   @relation(fields: [tenantId], references: [id])

  @@map("skills")
}

model TenantMemory {
  id         String    @id @default(cuid())
  tenantId   String
  key        String
  value      Json
  source     String    // who/what wrote it
  memoryType String    // WORKFLOW | USER_PREF | KNOWLEDGE | POLICY | SKILL_REGISTRY
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant     Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, memoryType])
  @@map("tenant_memory")
}

model MemoryItem {
  id             String    @id @default(cuid())
  tenantId       String
  scopeType      String
  scopeId        String
  key            String
  value          Json
  memoryType     String
  confidence     Float?
  source         String?
  sourceRunId    String?
  idempotencyKey String?
  contentHash    String?
  version        Int       @default(1)
  expiresAt      DateTime?
  // Approval status — added in migration 16. Existing rows default to
  // 'user_approved' (backward compat: any pre-existing memory was
  // necessarily user-curated since there was no agent-suggestion flow).
  // - 'extracted'      : auto-extracted from documents/website, awaits review
  // - 'suggested'      : agent proposed during a workflow run, awaits review
  // - 'user_approved'  : reviewer or user explicitly approved (only these
  //                     are loaded into agent prompts via grounding)
  // - 'rejected'       : reviewer explicitly rejected; never re-suggested
  status         String    @default("user_approved")
  // Who suggested it (when status='suggested') or extracted (when 'extracted')
  suggestedBy    String?
  // Who approved/rejected
  reviewedBy     String?
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  lastAccessedAt DateTime?

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  events         MemoryEvent[]

  @@unique([tenantId, scopeType, scopeId, key])
  @@index([tenantId, scopeType, scopeId])
  @@index([tenantId, memoryType])
  @@index([tenantId, status])
  @@index([tenantId, updatedAt])
  @@index([tenantId, deletedAt])
  @@map("memory_items")
}

model MemoryEvent {
  id             String    @id @default(cuid())
  tenantId       String
  memoryItemId   String?
  scopeType      String
  scopeId        String
  key            String
  action         String
  actorId        String?
  runId          String?
  idempotencyKey String?
  diff           Json?
  createdAt      DateTime  @default(now())

  tenant         Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memoryItem     MemoryItem? @relation(fields: [memoryItemId], references: [id], onDelete: SetNull)

  @@unique([tenantId, idempotencyKey])
  @@index([tenantId, createdAt])
  @@index([tenantId, action])
  @@map("memory_events")
}

model VectorDocument {
  id         String   @id @default(cuid())
  tenantId   String
  content    String   @db.Text
  // embedding stored via raw SQL (pgvector); Prisma doesn't natively support vector type
  metadata   Json?
  sourceKey  String?
  sourceType String   @default("DOCUMENT")
  chunkIndex Int      @default(0)
  scopeType  String?
  scopeId    String?
  contentHash String?
  // Soft FK to TenantDocument.id — when a file is uploaded via POST /documents/upload,
  // each chunk row carries the originating document id so we can list chunks by
  // document (preview) and delete chunks when the document is removed.
  documentId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, sourceType])
  @@index([tenantId, scopeType, scopeId])
  @@index([tenantId, sourceKey])
  @@index([documentId])
  @@map("vector_documents")
}

// Source-of-truth record for every file a tenant uploads via the dashboard.
// The raw bytes live in Supabase Storage under `tenant-documents/<tenantId>/<id>.<ext>`;
// this table holds the metadata + the URL the frontend uses to stream the file
// back. Chunked + embedded content lives in VectorDocument rows joined on documentId.
//
// Why a dedicated model instead of reusing VectorDocument: VectorDocument is
// chunk-level (one row per ~1k tokens). TenantDocument is document-level (one
// row per uploaded file). Treating them as the same thing makes preview, delete,
// and "recently uploaded files" queries awkward. Keeping them separate makes
// the lifecycle clear: upload creates 1 TenantDocument + N VectorDocument rows.
model TenantDocument {
  id           String   @id @default(cuid())
  tenantId     String
  // Uploader — null when uploaded via API key (future: service-account uploads)
  uploadedBy   String?
  fileName     String
  // MIME type from Content-Type, validated against an allowlist at upload time.
  mimeType     String
  sizeBytes   Int
  // Supabase Storage key: `tenant-documents/<tenantId>/<id>.<ext>`. Frontend
  // builds the signed URL at read-time so we never persist a URL that could
  // outlive its signature.
  storageKey   String   @unique
  // Hash of the file content (sha256, hex). Lets us dedupe identical uploads
  // across a tenant and detect silent corruption.
  contentHash  String?
  // Ingestion lifecycle:
  //   PENDING   — uploaded, not yet chunked/embedded
  //   INDEXED   — chunks live in VectorDocument, searchable
  //   FAILED    — ingestion failed, see ingestionError for reason
  //   DELETED   — soft-delete marker; storage object also removed
  status       String   @default("PENDING")
  ingestionError String?
  // Optional scope labels set at upload — e.g., { projectId, workflowId }
  // so the find_document tool can filter to the right context.
  metadata     Json?
  // Optional tags the user attaches at upload for organization in the Files tab.
  tags         String[] @default([])
  // Soft delete — storage object is still removed, this row stays for audit.
  deletedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, deletedAt])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
  @@map("tenant_documents")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  resource   String
  resourceId String?
  details    Json?
  ip         String?
  userAgent  String?
  severity   String   @default("INFO") // INFO | WARN | ERROR | CRITICAL
  createdAt  DateTime @default(now())

  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, action])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

model Integration {
  id          String    @id @default(cuid())
  tenantId    String
  provider    String
  status      String    @default("CONNECTED")
  displayName String?
  scopes      String[]  @default([])
  metadata    Json?
  lastUsedAt  DateTime?
  connectedBy String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  credentials IntegrationCredential?

  @@unique([tenantId, provider])
  @@index([tenantId, status])
  @@map("integrations")
}

model IntegrationCredential {
  id              String      @id @default(cuid())
  integrationId   String      @unique
  accessTokenEnc  String
  refreshTokenEnc String?
  expiresAt       DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  integration     Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@map("integration_credentials")
}

// Short-lived row created when a tenant starts an OAuth authorization flow
// (e.g. "Sign in with Google"). Stores the CSRF `state` token + the PKCE
// `codeVerifier` until the provider redirects back to the callback, at which
// point the row is read once and deleted. TTL enforced by the callback
// handler; a background sweeper can drop rows with expiresAt < now().
model OAuthState {
  id           String   @id @default(cuid())
  tenantId     String
  userId       String
  provider     String
  state        String   @unique
  codeVerifier String
  redirectUri  String
  scopes       String[] @default([])
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([expiresAt])
  @@map("oauth_states")
}

model WhatsappLink {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String
  phoneNumber String
  status      String   @default("PENDING")
  challengeCode String?
  challengeExpiresAt DateTime?
  verifiedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([phoneNumber])
  @@unique([tenantId, userId])
  @@index([tenantId])
  @@map("whatsapp_links")
}

model OnboardingState {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  completedSteps String[] @default([])
  dismissed      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("onboarding_states")
}

model WorkflowSchedule {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String
  name            String
  description     String?
  goal            String
  industry        String?
  cronExpression  String
  enabled         Boolean   @default(true)
  maxCostUsd      Float?
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  lastRunStatus   String?
  lastRunId       String?
  runCount        Int       @default(0)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, enabled])
  @@index([nextRunAt])
  @@map("workflow_schedules")
}

// ─── Vibe Coding: Project Models ────────────────────────────────────────────

model Project {
  id              String    @id @default(cuid())
  tenantId        String
  userId          String
  name            String
  description     String?   @db.Text
  framework       String    @default("nextjs") // nextjs | react-spa | react-native | fastify-api
  status          String    @default("DRAFT")  // DRAFT | GENERATING | BUILDING | READY | DEPLOYED | FAILED
  lastBuildError  String?   @db.Text           // FIX #17: Store last build error for debugging
  sandboxId       String?
  previewUrl      String?
  deploymentUrl   String?
  deploymentId    String?
  githubRepo      String?
  githubBranch    String?   @default("main")
  templateId      String?
  currentVersion  Int       @default(0)
  totalCostUsd    Float     @default(0)
  metadata        Json?     // architecture, config, env vars, etc.
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // FIX #16: Add proper User relation
  tenant          Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user            User                @relation(fields: [userId], references: [id])
  files           ProjectFile[]
  versions        ProjectVersion[]
  conversations   ProjectConversation[]

  @@index([tenantId, status])
  @@index([tenantId, userId])
  @@map("projects")
}

model ProjectFile {
  id         String   @id @default(cuid())
  projectId  String
  path       String   // e.g. "src/app/page.tsx"
  content    String   @db.Text
  language   String?  // tsx, ts, css, json, md, etc.
  size       Int      @default(0)
  hash       String?  // SHA-256 for diffing
  versionId  String?  // which version created/modified this
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // FIX #3: Removed isDeleted + soft-delete pattern.
  // Files are hard-deleted; use ProjectVersion.snapshotJson for history/rollback.
  @@unique([projectId, path])
  @@index([projectId])
  @@map("project_files")
}

model ProjectVersion {
  id           String   @id @default(cuid())
  projectId    String
  version      Int
  description  String?
  snapshotJson Json?    // full file tree snapshot for rollback
  diffJson     Json?    // files changed in this version
  createdBy    String   @default("system") // "user" | "agent" | "system"
  workflowId   String?  // optional link to the workflow that created this version
  createdAt    DateTime @default(now())

  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, version])
  @@index([projectId])
  @@map("project_versions")
}

model ProjectConversation {
  id         String   @id @default(cuid())
  projectId  String
  role       String   // "user" | "assistant" | "system"
  content    String   @db.Text
  metadata   Json?    // file references, agent info, cost, etc.
  workflowId String?
  createdAt  DateTime @default(now())

  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@map("project_conversations")
}

model UserLayout {
  id        String   @id @default(cuid())
  userId    String   @unique
  layout    Json     // SerializedLayout from shell-store
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("user_layouts")
}

