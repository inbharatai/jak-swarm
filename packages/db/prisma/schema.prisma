// ─────────────────────────────────────────────────────────────────────────
// Audit & Compliance v1 — control framework mapping (e.g. SOC2 Type 2)
// ─────────────────────────────────────────────────────────────────────────
//
// Three-table model:
//   1. ComplianceFramework — the framework definition (e.g. "SOC2 Type 2").
//      Global; not tenant-scoped. Seeded from packages/db/prisma/seed-data/
//      compliance-frameworks.ts.
//
//   2. ComplianceControl — individual control within a framework
//      (e.g. SOC2 CC6.1 "Logical Access Controls"). Many-to-one with
//      Framework. Global; auto-mapping rules live in code, not DB.
//
//   3. ControlEvidenceMapping — tenant-scoped link between a control
//      and a piece of evidence (an AuditLog row, a WorkflowArtifact,
//      etc.). One control accumulates many evidence mappings over time.
//      Auto-populated by the auto-mapping engine; can also be created
//      manually via the API for human-curated mappings.
//
// ControlAttestation — a periodic snapshot saying "as of date X, this
// tenant's control Y had N pieces of evidence covering period Z". The
// attestation document itself is a WorkflowArtifact (artifactType=
// 'control_attestation') signed via bundle-signing. This row is just
// the summary record so the UI can list attestations without fetching
// every artifact's bytes.

model ComplianceFramework {
  id          String   @id @default(cuid())
  // Stable slug used in URLs + auto-mapping rule lookups (e.g. "soc2-type2").
  slug        String   @unique
  name        String   // "SOC 2 Type 2"
  shortName   String   // "SOC 2"
  // Issuing body (e.g. "AICPA", "ISO/IEC", "HHS").
  issuer      String
  // Free-text description shown on the framework selector page.
  description String   @db.Text
  // Catalogue version we're seeding from (e.g. "2017 TSC, revised 2022").
  version     String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  controls    ComplianceControl[]

  @@map("compliance_frameworks")
}

model ComplianceControl {
  id            String   @id @default(cuid())
  frameworkId   String
  // Stable code from the source standard (e.g. "CC6.1", "P1.1").
  code          String
  // Trust Services Category for SOC2 (e.g. "Security", "Privacy") or
  // equivalent grouping for other frameworks.
  category      String
  // Common Criteria / Series identifier within the category (e.g. "CC6").
  series        String
  title         String
  description   String   @db.Text
  // Auto-mapping rule key — resolves to a function in the rule registry
  // that decides which evidence rows belong to this control. Null when
  // the control is human-mapped only (no automation).
  autoRuleKey   String?
  // Sub-control breakdown — JSON array of `{code, title, description}`.
  // E.g. SOC 2 CC6.1 has 11 sub-points (CC6.1.1 ... CC6.1.11). NULL
  // when the control has no published sub-points or the catalog hasn't
  // seeded them yet. Auditors use these to write attestation narratives
  // at sub-point granularity. The auto-mapping engine still maps
  // evidence to the parent control today; sub-point routing is roadmap.
  subControls   Json?
  // Display order within its category.
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  framework     ComplianceFramework @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  evidence      ControlEvidenceMapping[]

  @@unique([frameworkId, code])
  @@index([frameworkId, category, sortOrder])
  @@map("compliance_controls")
}

model ControlEvidenceMapping {
  id           String   @id @default(cuid())
  tenantId     String
  controlId    String
  // What kind of row this mapping points at.
  //   - 'audit_log'        → AuditLog.id
  //   - 'workflow'         → Workflow.id
  //   - 'approval'         → ApprovalRequest.id
  //   - 'artifact'         → WorkflowArtifact.id
  //   - 'evidence_bundle'  → WorkflowArtifact.id where artifactType='evidence_bundle'
  evidenceType String
  evidenceId   String
  // When the underlying evidence was produced (denormalised so the
  // attestation can do period queries without joining 4 tables).
  evidenceAt   DateTime
  // Who created the mapping. 'auto-mapper' for engine-created rows;
  // user id for human curated rows.
  mappedBy     String
  // 'auto' = engine-created via autoRuleKey; 'manual' = human curated.
  mappingSource String  @default("auto")
  // Optional human note when mappingSource=manual.
  notes        String?  @db.Text
  createdAt    DateTime @default(now())

  control      ComplianceControl @relation(fields: [controlId], references: [id], onDelete: Cascade)

  @@unique([tenantId, controlId, evidenceType, evidenceId])
  @@index([tenantId, controlId, evidenceAt])
  @@index([tenantId, evidenceAt])
  @@map("control_evidence_mappings")
}

// Manual evidence — human-curated rows that supplement the auto-mapping
// engine. Used for organisational policies, signed BAAs, vendor SOC
// reports, training records, and other artefacts that no audit log
// can produce.
//
// Each ManualEvidence row appears in the control's evidence drill-in
// alongside auto-mapped rows; both count toward coverage. The auto-
// mapper never deletes manual evidence — it only adds/upserts auto rows.
model ManualEvidence {
  id                  String    @id @default(cuid())
  tenantId            String
  controlId           String
  title               String
  description         String    @db.Text
  // Optional FK (soft — no cascade) to a WorkflowArtifact (e.g. an
  // uploaded PDF policy). When set, the UI can deep-link to download.
  attachedArtifactId  String?
  createdBy           String
  // For period-scoped attestations, the date the evidence is "valid as
  // of". Defaults to createdAt when not supplied — operators can backdate
  // to reflect when a policy actually went into effect.
  evidenceAt          DateTime  @default(now())
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  // Soft-delete pattern matches WorkflowArtifact + TenantDocument.
  deletedAt           DateTime?

  @@index([tenantId, controlId, deletedAt])
  @@index([tenantId, evidenceAt])
  @@map("manual_evidence")
}

// ScheduledAttestation — cron-driven recurring attestation generation.
//
// Each row represents a single recurring schedule for a (tenant, framework)
// pair. The AttestationScheduler service polls these rows every minute
// and fires generation when `nextRunAt` has passed; afterwards it
// computes the next occurrence from the cron expression and updates
// the row.
//
// Period semantics: each fire produces an attestation covering the
// `windowDays` days immediately preceding the firing time. So a
// weekly schedule with windowDays=7 always covers the previous week.
//
// Honest gating: schedules require operator opt-in (active=true) AND
// EVIDENCE_SIGNING_SECRET if signBundles=true. The scheduler skips
// schedules whose dependencies aren't satisfied (logs + leaves
// nextRunAt unchanged so a future tick retries).
model ScheduledAttestation {
  id              String    @id @default(cuid())
  tenantId        String
  frameworkId     String
  // Standard 5-field cron expression in UTC (e.g. "0 0 * * 1" = every
  // Monday midnight UTC). Validated at write time via cron-parser.
  cronExpression  String
  // How many days back from the firing time the attestation covers.
  windowDays      Int       @default(7)
  // When true, attempts to also create a signed evidence bundle alongside.
  // Requires EVIDENCE_SIGNING_SECRET; failure to sign leaves the PDF
  // attestation but logs a warning.
  signBundles     Boolean   @default(false)
  // Optional metadata stamped on every generated attestation
  // (e.g. control framework variant, customer name).
  metadata        Json?
  // Operator opt-in — defaults to false; flipping to true starts firings
  // on the next scheduler tick.
  active          Boolean   @default(false)
  // Computed by the scheduler from cronExpression at create + after
  // every fire. NULL means "schedule paused" — never fired again until
  // active flips back on.
  nextRunAt       DateTime?
  // Timestamp of the most recent successful fire (for the UI history table).
  lastRunAt       DateTime?
  // Last fire's outcome — "success" or "failed:<reason>" for the UI.
  lastRunStatus   String?
  // ID of the most recent attestation row produced by this schedule
  // (lets the UI deep-link to the latest output).
  lastAttestationId String?
  createdBy       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active, nextRunAt])
  @@index([tenantId, frameworkId])
  @@map("scheduled_attestations")
}

model ControlAttestation {
  id              String   @id @default(cuid())
  tenantId        String
  frameworkId     String
  // Period covered by this attestation.
  periodStart     DateTime
  periodEnd       DateTime
  // Per-control evidence counts at attestation time, JSON-shaped:
  //   [{ controlId, controlCode, evidenceCount }, ...]
  controlSummary  Json
  // Total evidence rows across all controls for this period.
  totalEvidence   Int
  // Coverage = controls with ≥1 evidence row in period / total controls.
  coveragePercent Float
  // The WorkflowArtifact that holds the signed PDF + JSON manifest.
  // Null while the attestation is still generating; populated when ready.
  artifactId      String?
  generatedBy     String
  createdAt       DateTime @default(now())

  @@index([tenantId, frameworkId, createdAt])
  @@map("control_attestations")
}

// ─────────────────────────────────────────────────────────────────────────
// Audit & Compliance v2 — Audit Run product
// ─────────────────────────────────────────────────────────────────────────
//
// Distinct from generic Workflow + Compliance attestation systems. An
// AuditRun represents a full audit engagement (e.g. "Q1 2026 SOC 2 Type 2
// readiness check for Apex Health Network"). It owns ControlTest rows
// (one per control in the framework), AuditException rows (created when a
// test fails), and AuditWorkpaper rows (one per control with rich
// narrative).
//
// State machine (audit-run-status enum stored as String):
//   PLANNING       — created, awaiting plan() call
//   PLANNED        — control tests seeded
//   MAPPING        — auto-mapper running
//   TESTING        — control tests running
//   REVIEWING      — workpapers generated, awaiting reviewer
//   READY_TO_PACK  — all workpapers approved
//   FINAL_PACK     — final pack generated
//   COMPLETED      — terminal: pack delivered
//   FAILED         — terminal: error before pack
//   CANCELLED      — terminal: operator cancelled

model AuditRun {
  id                  String    @id @default(cuid())
  tenantId            String
  userId              String
  // Stable framework slug (e.g. "soc2-type2") — soft FK to ComplianceFramework.slug
  frameworkSlug       String
  // Human-friendly title shown in the workspace (e.g. "Q1 2026 SOC 2 readiness")
  title               String
  // Optional scope description (e.g. "production cluster + customer support workflows")
  scope               String?   @db.Text
  // Period the audit covers
  periodStart         DateTime
  periodEnd           DateTime
  // State machine
  status              String    @default("PLANNING")
  // Risk summary computed from test results: 'low' / 'medium' / 'high' / 'critical'
  riskSummary         String?
  // Computed coverage % across ControlTest rows (passed / total).
  coveragePercent     Float?
  // Set when status transitions to FINAL_PACK; points at the signed evidence bundle artifact
  finalPackArtifactId String?
  // Optional metadata (control framework variant, customer name, etc.)
  metadata            Json?
  // Soft-delete pattern matches WorkflowArtifact + TenantDocument
  deletedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  controlTests        ControlTest[]
  exceptions          AuditException[]
  workpapers          AuditWorkpaper[]

  @@index([tenantId, status, deletedAt])
  @@index([tenantId, frameworkSlug])
  @@index([tenantId, createdAt])
  @@map("audit_runs")
}

// ControlTest — one row per (auditRun, control). Records the test
// procedure, evidence considered, result, and any reviewer notes.
//
// Statuses: 'not_started' / 'evidence_missing' / 'evidence_received' /
// 'testing' / 'passed' / 'failed' / 'exception_found' /
// 'reviewer_required' / 'approved' / 'rejected' / 'remediated'
//
// Result: 'pass' / 'fail' / 'exception' / 'needs_evidence' (terminal)
model ControlTest {
  id              String    @id @default(cuid())
  tenantId        String
  auditRunId      String
  // Soft FK to ComplianceControl.id — the control being tested
  controlId       String
  // Snapshot of the control code at test time (e.g. "CC6.1") so the
  // workpaper survives if the catalog is reorganised
  controlCode     String
  controlTitle   String
  // Test procedure narrative (LLM-generated or human-curated)
  testProcedure   String?   @db.Text
  // Per-test status (state machine — see comment above model)
  status          String    @default("not_started")
  // Terminal result (when status reaches a terminal state)
  result          String?
  // LLM rationale for the result
  rationale       String?   @db.Text
  // 0-1 confidence — when <0.7 the workpaper requires reviewer override
  confidence      Float?
  // Snapshot of evidence considered (audit_log/workflow/approval/artifact/manual_evidence ids)
  evidenceConsidered Json?
  evidenceCount   Int       @default(0)
  // Set when result='fail' or 'exception' → AuditException row id
  exceptionId     String?
  startedAt       DateTime?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  auditRun        AuditRun  @relation(fields: [auditRunId], references: [id], onDelete: Cascade)

  @@unique([auditRunId, controlId])
  @@index([tenantId, auditRunId, status])
  @@index([tenantId, controlId])
  @@map("control_tests")
}

// AuditException — created when a ControlTest result is 'fail' or
// 'exception'. Tracked through remediation lifecycle.
//
// Severity: 'low' / 'medium' / 'high' / 'critical' (from control's riskLevel)
// Status: 'open' / 'remediation_planned' / 'remediation_in_progress' /
// 'remediation_complete' / 'accepted' / 'rejected' / 'closed'
model AuditException {
  id              String    @id @default(cuid())
  tenantId        String
  auditRunId      String
  controlTestId   String?
  controlId       String
  controlCode     String
  severity        String    @default("medium")
  // Description of the exception (LLM-synthesised or human)
  description     String    @db.Text
  // Root cause analysis
  cause           String?   @db.Text
  // Business impact narrative
  impact          String?   @db.Text
  // Remediation plan (suggested by AI or curated)
  remediationPlan String?   @db.Text
  remediationOwner String?
  remediationDueDate DateTime?
  status          String    @default("open")
  // Reviewer decision when accepted/rejected
  reviewerStatus  String?
  reviewerComment String?   @db.Text
  reviewedBy      String?
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  auditRun        AuditRun  @relation(fields: [auditRunId], references: [id], onDelete: Cascade)

  @@index([tenantId, auditRunId, status])
  @@index([tenantId, severity, status])
  @@map("audit_exceptions")
}

// AuditWorkpaper — per-control narrative pulling together control,
// tests, evidence, exceptions, reviewer notes. Generated as a real PDF
// via existing exportPdf() and persisted as a WorkflowArtifact with
// artifactType='workpaper' + approvalState='REQUIRES_APPROVAL'.
//
// Status: 'draft' / 'needs_evidence' / 'needs_review' / 'rejected' /
// 'approved' / 'final'
model AuditWorkpaper {
  id              String    @id @default(cuid())
  tenantId        String
  auditRunId      String
  controlTestId   String?
  controlId       String
  controlCode     String
  controlTitle    String
  // The PDF artifact id (FK to workflow_artifacts via app code; no schema FK
  // because WorkflowArtifact has its own approval gate flow)
  artifactId      String?
  // Status (mirrors WorkflowArtifact.approvalState semantics; 'final' set
  // once included in a final pack)
  status          String    @default("draft")
  // Reviewer narrative override (when reviewer edits the LLM-generated text)
  reviewerNotes   String?   @db.Text
  generatedBy     String
  reviewedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  auditRun        AuditRun  @relation(fields: [auditRunId], references: [id], onDelete: Cascade)

  @@unique([auditRunId, controlId])
  @@index([tenantId, auditRunId, status])
  @@map("audit_workpapers")
}

// ─────────────────────────────────────────────────────────────────────────
// Migration 16 — Company Brain + Intent vocabulary + Workflow templates
// ─────────────────────────────────────────────────────────────────────────
//
// Adds the four primitives the layman-friendly company OS needs:
//   1. CompanyProfile  — name/industry/brand voice/audience/competitors/etc.
//   2. IntentRecord    — persisted intent classification per workflow
//   3. WorkflowTemplate— pre-tuned best-practice decompositions per intent
//   4. CompanyKnowledgeSource — URLs the user wants ingested (separate from
//                              uploaded TenantDocuments)
//
// All additive — no changes to existing models. Approval gates enforced at
// the service layer via the `status` field.

// CompanyProfile — one row per tenant (logical singleton).
//
// Status:
//   - 'extracted'    : LLM extracted from uploaded docs/URLs; awaits user review
//   - 'user_approved': user reviewed + confirmed; agents may load this profile
//                     into their system prompt for grounding
//   - 'manual'       : user typed everything by hand, no extraction
//
// The agent-grounding layer ONLY loads profiles where status='user_approved'
// or status='manual'. Extracted-but-unapproved profiles are visible to the
// user for review but NOT used by agents until approved. No silent
// overwrite — the user must explicitly approve.
model CompanyProfile {
  id                  String    @id @default(cuid())
  tenantId            String    @unique
  name                String?
  industry            String?
  description         String?   @db.Text
  productsServices    Json?     // Array of {name, description}
  targetCustomers     String?   @db.Text
  brandVoice          String?   @db.Text  // e.g. "professional, warm, jargon-light"
  competitors         Json?     // Array of {name, url?, notes?}
  pricing             String?   @db.Text
  websiteUrl          String?
  goals               String?   @db.Text
  constraints         String?   @db.Text
  preferredChannels   Json?     // ['email', 'slack', 'whatsapp']
  status              String    @default("extracted")
  // Confidence per LLM extraction (0-1). Null when status='manual'.
  extractionConfidence Float?
  // Source documents the extraction was based on (TenantDocument ids)
  sourceDocumentIds   Json?
  reviewedBy          String?
  reviewedAt          DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant              Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("company_profiles")
}

// CompanyKnowledgeSource — URLs the user wants ingested into the Brain.
// Separate from TenantDocument because this is for ongoing tracking
// (monitor a competitor's pricing page, watch for changes, etc.).
model CompanyKnowledgeSource {
  id          String    @id @default(cuid())
  tenantId    String
  url         String
  kind        String    // 'website' | 'competitor' | 'pricing' | 'product' | 'blog' | 'other'
  title       String?
  // Last successful crawl
  lastCrawledAt DateTime?
  // Status of last crawl: 'pending' | 'crawled' | 'failed'
  lastCrawlStatus String  @default("pending")
  lastCrawlError String?  @db.Text
  // Vector document ids produced from the crawl (so we can re-ingest)
  vectorDocumentIds Json?
  createdBy   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@unique([tenantId, url])
  @@index([tenantId, kind, deletedAt])
  @@map("company_knowledge_sources")
}

// IntentRecord — persists the Commander's intent classification per
// workflow run, so we have a queryable history (analytics, future
// follow-up routing, audit trail).
//
// The `intent` field is constrained at the application layer to one of
// the 18 named values defined in COMPANY_OS_INTENTS (packages/agents/
// src/intents/intent-vocabulary.ts).
model IntentRecord {
  id                String    @id @default(cuid())
  tenantId          String
  workflowId        String?   // null when Commander short-circuits with directAnswer
  userId            String
  rawInput          String    @db.Text
  intent            String    // one of the 18 named intents
  intentConfidence  Float?    // 0-1, LLM-self-reported
  subFunction       String?
  urgency           Int?      // 1-5
  riskIndicators    Json?     // String[]
  requiredOutputs   Json?     // String[]
  workflowTemplateId String?  // FK to WorkflowTemplate.id when matched
  clarificationNeeded Boolean @default(false)
  clarificationQuestion String? @db.Text
  directAnswer      String?   @db.Text  // when Commander short-circuited
  createdAt         DateTime  @default(now())

  @@index([tenantId, intent, createdAt])
  @@index([tenantId, workflowId])
  @@index([tenantId, userId, createdAt])
  @@map("intent_records")
}

// WorkflowTemplate — pre-tuned best-practice workflow specifications,
// matched to user intents. The Commander/Planner can look up a template
// by intent and use its tuned decomposition instead of asking the LLM
// to re-derive it from scratch.
//
// status: 'active' | 'inactive' | 'experimental'
model WorkflowTemplate {
  id              String    @id @default(cuid())
  // Per-tenant overrides allowed. tenantId=null means a system template
  // available to all tenants (the seeded library).
  tenantId        String?
  intent          String    // one of the 18 named intents
  name            String
  description     String    @db.Text
  // The tasks the Planner should produce. Array of {id, name, agentRole,
  // toolsRequired, dependsOn, riskLevel, requiresApproval, retryable}.
  tasksJson       Json
  // Required company-context fields (e.g. ['brandVoice', 'targetCustomers'])
  // The Commander surfaces "missing inputs" when these aren't on the tenant's
  // CompanyProfile.
  requiredCompanyContext Json?
  // Required user inputs (e.g. ['websiteUrl', 'audience'])
  requiredUserInputs Json?
  // Approval gates — array of step ids that need approval before continuing.
  approvalGates   Json?
  // Expected artifact types (e.g. ['report.pdf', 'campaign.json'])
  expectedArtifacts Json?
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([tenantId, intent, name])
  @@index([intent, status])
  @@map("workflow_templates")
}
