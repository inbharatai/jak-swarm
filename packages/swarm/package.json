{
  "name": "@jak-swarm/swarm",
  "version": "0.1.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "pretypecheck": "pnpm -w --filter @jak-swarm/verification build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@jak-swarm/agents": "workspace:*",
    "@jak-swarm/industry-packs": "workspace:*",
    "@jak-swarm/shared": "workspace:*",
    "@jak-swarm/tools": "workspace:^",
    "@jak-swarm/verification": "workspace:^",
    "@langchain/core": "^1.1.41",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint": "^1.0.1",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
