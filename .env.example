# ============================================================================
# JAK Swarm -- Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================


# ── Database (required) ──────────────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL="postgresql://jakswarm:jakswarm@localhost:5432/jakswarm"

# Redis (optional -- used for scheduling and queues)
REDIS_URL="redis://localhost:6379"


# ── Authentication (required) ────────────────────────────────────────────────

# Random secret for session signing. Generate with: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-random-32-char-secret"

# Base URL for auth callbacks
AUTH_URL="http://localhost:3000"


# ── LLM Providers ───────────────────────────────────────────────────────────
# At minimum, set OPENAI_API_KEY. Additional providers are optional and
# enable tier-based routing (cheaper models for simple tasks, premium for
# planning/verification).

# OpenAI (required -- primary provider)
OPENAI_API_KEY="sk-..."
OPENAI_ORG_ID=""

# Anthropic (optional -- Claude models for premium reasoning)
ANTHROPIC_API_KEY=""

# Google Gemini (optional -- balanced cost/quality)
GEMINI_API_KEY=""

# DeepSeek (optional -- low-cost worker tasks)
DEEPSEEK_API_KEY=""

# OpenRouter (optional -- access 100+ models via single key)
OPENROUTER_API_KEY=""

# Ollama (optional -- local models, zero API cost)
OLLAMA_URL=""
OLLAMA_MODEL=""

# Routing strategy: cost_optimized | quality_first | local_first
LLM_ROUTING_STRATEGY="cost_optimized"


# ── Voice Pipeline (optional) ───────────────────────────────────────────────

# OpenAI Realtime API for voice agent
OPENAI_REALTIME_MODEL="gpt-4o-realtime-preview"

# Deepgram -- speech-to-text adapter
DEEPGRAM_API_KEY=""

# ElevenLabs -- text-to-speech adapter
ELEVENLABS_API_KEY=""
ELEVENLABS_VOICE_ID=""


# ── Email -- Gmail IMAP/SMTP (optional) ─────────────────────────────────────
# Without these, the system uses mock email adapters.
# To use real Gmail:
#   1. Enable 2FA on your Google account
#   2. Generate an app password at https://myaccount.google.com/apppasswords
#   3. Paste the 16-char app password below (spaces are fine)

GMAIL_EMAIL=""
GMAIL_APP_PASSWORD=""


# ── Calendar -- CalDAV (optional) ───────────────────────────────────────────
# For Google Calendar, use your Google credentials with CalDAV.
# Without these, the system uses mock calendar adapters.

CALDAV_URL=""
CALDAV_USERNAME=""
CALDAV_PASSWORD=""


# ── Phoring.ai Integration (optional) ───────────────────────────────────────
# Forecasting and knowledge graph tools

PHORING_API_URL=""
PHORING_API_KEY=""


# ── Temporal -- Durable Workflows (optional) ────────────────────────────────
# Required only if using Temporal for long-running workflow orchestration.

TEMPORAL_ADDRESS="localhost:7233"
TEMPORAL_NAMESPACE="jak-swarm"
TEMPORAL_TASK_QUEUE="jak-main"


# ── Application ─────────────────────────────────────────────────────────────

NODE_ENV="development"
API_PORT=4000
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
LOG_LEVEL="info"

# Require human approval for high-risk actions by default
DEFAULT_APPROVAL_REQUIRED=true
