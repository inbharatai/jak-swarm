{
  "name": "@jak-swarm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=.env src/index.ts",
    "worker": "tsx --env-file=.env src/worker-entry.ts",
    "start": "node --env-file=.env dist/index.js",
    "pretypecheck": "pnpm -w --filter @jak-swarm/shared --filter @jak-swarm/verification --filter @jak-swarm/swarm --filter !jak-swarm build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.2.1",
    "@jak-swarm/agents": "workspace:*",
    "@jak-swarm/db": "workspace:*",
    "@jak-swarm/industry-packs": "workspace:*",
    "@jak-swarm/security": "workspace:*",
    "@jak-swarm/shared": "workspace:*",
    "@jak-swarm/swarm": "workspace:*",
    "@jak-swarm/tools": "workspace:*",
    "@opentelemetry/auto-instrumentations-node": "^0.72.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.214.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.214.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@sentry/node": "^10.49.0",
    "@supabase/supabase-js": "^2.101.1",
    "bcryptjs": "^2.4.3",
    "cron-parser": "^5.5.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "prom-client": "^15.1.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.10.7",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
