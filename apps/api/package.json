    "@fastify/swagger": "^9.2.0",
    "@fastify/swagger-ui": "^5.2.1",
    "@jak-swarm/agents": "workspace:*",
    "@jak-swarm/db": "workspace:*",
    "@jak-swarm/shared": "workspace:*",
    "@jak-swarm/swarm": "workspace:*",
    "@jak-swarm/tools": "workspace:*",
    "bcryptjs": "^2.4.3",
    "cron-parser": "^5.5.0",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
