# .env.render-grafana-agent — template for sync-env-to-render.sh jak-swarm-grafana-agent
#
# Copy to .env.render-grafana-agent (gitignored), fill in, then:
#   ./scripts/automation/sync-env-to-render.sh jak-swarm-grafana-agent < .env.render-grafana-agent
#
# All three values come from Grafana Cloud UI:
#   Connections → Prometheus → "Send Metrics"
#
# The Remote Write URL typically ends with /api/prom/push.

GRAFANA_CLOUD_PROM_URL=https://prometheus-prod-XX-prod-XX.grafana.net/api/prom/push
GRAFANA_CLOUD_PROM_USER=1234567
GRAFANA_CLOUD_PROM_API_KEY=glc_...
