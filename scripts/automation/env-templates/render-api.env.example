# .env.render-api — template for sync-env-to-render.sh jak-swarm-api
#
# Copy to .env.render-api (gitignored), fill in secrets, then:
#   ./scripts/automation/sync-env-to-render.sh jak-swarm-api < .env.render-api
#
# This is the CRITICAL FLIP file. The only var that MUST change on the
# existing API service during migration is WORKFLOW_WORKER_MODE=standalone.
# The rest are already on the service — keeping them in the file just
# makes the state explicit and reproducible.

# Runtime
NODE_ENV=production
LOG_LEVEL=warn
PORT=4000
API_PORT=4000

# CORS — comma-separated, NO spaces after commas
CORS_ORIGINS=https://jakswarm.com,https://www.jakswarm.com

# ★ THE CRITICAL FLIP ★
WORKFLOW_WORKER_MODE=standalone

# Fail fast if Redis is missing
REQUIRE_REDIS_IN_PROD=true

# Supabase (public keys — safe to commit values, pasted here for sync)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY

# Supabase Postgres (via pooler for runtime, direct for migrations)
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres

# Upstash Redis (rediss:// — double s for TLS)
REDIS_URL=rediss://default:YOUR_ROTATED_PASSWORD@YOUR_DB.upstash.io:6379

# Auth secret (generate fresh once, copy to worker to match)
AUTH_SECRET=GENERATED_BY_RENDER_OR_OPENSSL_RAND_HEX_32

# LLM provider keys
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-api03-...
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=
