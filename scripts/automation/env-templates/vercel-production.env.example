# .env.vercel-production — template for configure-vercel-env.sh
#
# Copy to .env.vercel-production (gitignored), fill in, then:
#   ./scripts/automation/configure-vercel-env.sh < .env.vercel-production
#
# Only NEXT_PUBLIC_* vars belong here. The script refuses non-public keys
# to avoid accidentally bundling a backend secret into the browser.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY
NEXT_PUBLIC_API_URL=https://jak-swarm-api.onrender.com

# Paddle checkout links (only if you use Paddle)
# NEXT_PUBLIC_PADDLE_PRO_LINK=https://pay.paddle.io/hsc_...
# NEXT_PUBLIC_PADDLE_TEAM_LINK=https://pay.paddle.io/hsc_...
