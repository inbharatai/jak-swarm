# .env.render-worker — template for sync-env-to-render.sh jak-swarm-worker
#
# Copy to .env.render-worker (gitignored), fill in secrets, then:
#   ./scripts/automation/sync-env-to-render.sh jak-swarm-worker < .env.render-worker
#
# AUTH_SECRET MUST match the API service's value. REDIS_URL and DATABASE_URL
# must also match exactly — worker + API coordinate through them.

# Runtime
NODE_ENV=production
LOG_LEVEL=info

# Worker-specific tuning
WORKFLOW_WORKER_INSTANCE_ID=$RENDER_SERVICE_NAME
WORKFLOW_QUEUE_CONCURRENCY=2
WORKFLOW_QUEUE_POLL_INTERVAL_MS=1000
WORKFLOW_QUEUE_LEASE_TTL_MS=60000
WORKER_METRICS_PORT=9464
REQUIRE_REDIS_IN_PROD=true

# Shared with API (must be identical values)
DATABASE_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres.YOUR_REF:PASSWORD@aws-0-YOUR_REGION.pooler.supabase.com:5432/postgres
REDIS_URL=rediss://default:YOUR_ROTATED_PASSWORD@YOUR_DB.upstash.io:6379
AUTH_SECRET=COPY_FROM_API_SERVICE_EXACTLY

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=REPLACE_WITH_ANON_KEY

# LLM keys — same as API
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-api03-...
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# OLLAMA_BASE_URL=
